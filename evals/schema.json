{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/muend/geoai-skills/evals/schema.json",
  "title": "GeoAI Skills evaluation suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skill", "evals"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "skill": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "evals": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "prompt", "expected_behavior"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "maxLength": 80
          },
          "prompt": {
            "type": "string",
            "minLength": 10,
            "maxLength": 2000
          },
          "expected_behavior": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 10,
              "maxLength": 1000
            }
          },
          "forbidden_behavior": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 10,
              "maxLength": 1000
            }
          },
          "should_trigger": {
            "type": "boolean",
            "default": true
          },
          "expected_route": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          },
          "critical": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
