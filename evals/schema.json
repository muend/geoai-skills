{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/muend/geoai-skills/evals/schema.json",
  "title": "GeoAI Skills evaluation suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skill", "evals"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "skill": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "evals": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "prompt", "case_types", "expected_behavior"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "maxLength": 80
          },
          "prompt": {
            "type": "string",
            "minLength": 10,
            "maxLength": 2000
          },
          "case_types": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "enum": [
                "positive",
                "negative",
                "ambiguous",
                "collision",
                "artifact-correctness"
              ]
            }
          },
          "expected_behavior": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 10,
              "maxLength": 1000
            }
          },
          "forbidden_behavior": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 10,
              "maxLength": 1000
            }
          },
          "should_trigger": {
            "type": "boolean",
            "default": true
          },
          "expected_route": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          },
          "critical": {
            "type": "boolean",
            "default": false
          },
          "behavior_class": {
            "enum": [
              "routing-only",
              "advisory",
              "fixture-backed",
              "artifact-producing"
            ]
          },
          "interaction_mode": {
            "enum": ["clarify", "deliver", "clarify_then_provisional"]
          },
          "tool_profile": {
            "enum": ["read-only", "workspace-write"]
          },
          "fixtures": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "workspace_path"],
              "properties": {
                "source": {
                  "type": "string",
                  "pattern": "^fixtures/(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
                  "not": {"pattern": "(^|/)\\.\\.(/|$)"}
                },
                "workspace_path": {
                  "type": "string",
                  "pattern": "^(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
                  "not": {"pattern": "(^|/)\\.\\.(/|$)"}
                }
              }
            }
          },
          "expected_artifacts": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "media_type"],
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
                  "not": {"pattern": "(^|/)\\.\\.(/|$)"}
                },
                "media_type": {
                  "type": "string",
                  "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$"
                },
                "required": {
                  "type": "boolean",
                  "default": true
                }
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "required": ["behavior_class"],
              "properties": {
                "behavior_class": {"not": {"const": "routing-only"}}
              }
            },
            "then": {"required": ["interaction_mode"]}
          },
          {
            "if": {"required": ["interaction_mode"]},
            "then": {
              "required": ["behavior_class"],
              "properties": {
                "behavior_class": {"not": {"const": "routing-only"}}
              }
            }
          },
          {
            "if": {
              "required": ["behavior_class"],
              "properties": {"behavior_class": {"const": "fixture-backed"}}
            },
            "then": {"required": ["fixtures"]}
          },
          {
            "if": {
              "required": ["behavior_class"],
              "properties": {"behavior_class": {"const": "artifact-producing"}}
            },
            "then": {
              "required": ["expected_artifacts", "tool_profile"],
              "properties": {"tool_profile": {"const": "workspace-write"}}
            }
          }
        ]
      }
    }
  }
}
