{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/muend/geoai-skills/evals/run-schema.json",
  "title": "GeoAI Skills evaluation run contracts",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "skillName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "manifestCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "skill",
        "eval_id",
        "prompt",
        "should_trigger",
        "expected_route",
        "expected_behavior",
        "forbidden_behavior",
        "critical",
        "case_sha256",
        "skill_sha256"
      ],
      "properties": {
        "case_id": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"},
        "skill": {"$ref": "#/$defs/skillName"},
        "eval_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "prompt": {"type": "string", "minLength": 10},
        "should_trigger": {"type": "boolean"},
        "expected_route": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/skillName"}
        },
        "expected_behavior": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 10}
        },
        "forbidden_behavior": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 10}
        },
        "critical": {"type": "boolean"},
        "case_sha256": {"$ref": "#/$defs/sha256"},
        "skill_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema_version",
        "suite_sha256",
        "runtime",
        "model",
        "condition",
        "available_skills",
        "cases"
      ],
      "properties": {
        "kind": {"const": "geoai-eval-manifest"},
        "schema_version": {"const": 1},
        "suite_sha256": {"$ref": "#/$defs/sha256"},
        "runtime": {"type": "string", "minLength": 1, "maxLength": 100},
        "model": {"type": "string", "minLength": 1, "maxLength": 200},
        "condition": {"enum": ["skills-enabled", "skills-disabled"]},
        "available_skills": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/skillName"}
        },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/manifestCase"}
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "case_id", "prompt"],
      "properties": {
        "schema_version": {"const": 1},
        "case_id": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"},
        "prompt": {"type": "string", "minLength": 10}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0}
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "case_id",
        "runtime",
        "model",
        "condition",
        "response",
        "activated_skills"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "case_id": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"},
        "runtime": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "condition": {"enum": ["skills-enabled", "skills-disabled"]},
        "response": {"type": "string"},
        "activated_skills": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/skillName"}
        },
        "latency_ms": {"type": "integer", "minimum": 0},
        "usage": {"$ref": "#/$defs/usage"},
        "error": {"type": "string", "minLength": 1}
      }
    },
    "expectedCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion", "met", "evidence"],
      "properties": {
        "criterion": {"type": "string", "minLength": 10},
        "met": {"type": "boolean"},
        "evidence": {"type": "string"}
      }
    },
    "forbiddenCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion", "observed", "evidence"],
      "properties": {
        "criterion": {"type": "string", "minLength": 10},
        "observed": {"type": "boolean"},
        "evidence": {"type": "string"}
      }
    },
    "judgment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "expected_behavior",
        "forbidden_behavior",
        "critical_failure"
      ],
      "properties": {
        "case_id": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"},
        "expected_behavior": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/expectedCheck"}
        },
        "forbidden_behavior": {
          "type": "array",
          "items": {"$ref": "#/$defs/forbiddenCheck"}
        },
        "critical_failure": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    },
    "judgmentSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "suite_sha256", "judge", "judgments"],
      "properties": {
        "schema_version": {"const": 1},
        "suite_sha256": {"$ref": "#/$defs/sha256"},
        "judge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": {
            "kind": {"enum": ["human", "model", "rule"]},
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1}
          }
        },
        "judgments": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/judgment"}
        }
      }
    },
    "caseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "skill",
        "routing_outcome",
        "route_match",
        "behavior_pass",
        "expected_met",
        "expected_total",
        "forbidden_violations",
        "critical_failure",
        "response_error"
      ],
      "properties": {
        "case_id": {"type": "string"},
        "skill": {"$ref": "#/$defs/skillName"},
        "routing_outcome": {"enum": ["tp", "tn", "fp", "fn"]},
        "route_match": {"type": "boolean"},
        "behavior_pass": {"type": "boolean"},
        "expected_met": {"type": "integer", "minimum": 0},
        "expected_total": {"type": "integer", "minimum": 1},
        "forbidden_violations": {"type": "integer", "minimum": 0},
        "critical_failure": {"type": "boolean"},
        "response_error": {"type": "boolean"}
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "suite_sha256",
        "runtime",
        "model",
        "condition",
        "judge",
        "coverage",
        "routing",
        "behavior",
        "critical",
        "usage"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "suite_sha256": {"$ref": "#/$defs/sha256"},
        "runtime": {"type": "string"},
        "model": {"type": "string"},
        "condition": {"enum": ["skills-enabled", "skills-disabled"]},
        "judge": {"type": "object"},
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cases", "responses", "judgments"],
          "properties": {
            "cases": {"type": "integer", "minimum": 0},
            "responses": {"type": "integer", "minimum": 0},
            "judgments": {"type": "integer", "minimum": 0}
          }
        },
        "routing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tp", "tn", "fp", "fn", "precision", "recall", "accuracy", "route_accuracy"],
          "properties": {
            "tp": {"type": "integer", "minimum": 0},
            "tn": {"type": "integer", "minimum": 0},
            "fp": {"type": "integer", "minimum": 0},
            "fn": {"type": "integer", "minimum": 0},
            "precision": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "recall": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "accuracy": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "route_accuracy": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
          }
        },
        "behavior": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed_cases", "judged_cases", "pass_rate", "criteria_met", "criteria_total", "forbidden_violations"],
          "properties": {
            "passed_cases": {"type": "integer", "minimum": 0},
            "judged_cases": {"type": "integer", "minimum": 0},
            "pass_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "criteria_met": {"type": "integer", "minimum": 0},
            "criteria_total": {"type": "integer", "minimum": 0},
            "forbidden_violations": {"type": "integer", "minimum": 0}
          }
        },
        "critical": {
          "type": "object",
          "additionalProperties": false,
          "required": ["evaluated_cases", "failures", "failure_rate"],
          "properties": {
            "evaluated_cases": {"type": "integer", "minimum": 0},
            "failures": {"type": "integer", "minimum": 0},
            "failure_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
          }
        },
        "usage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_tokens", "output_tokens", "latency_ms"],
          "properties": {
            "input_tokens": {"type": "integer", "minimum": 0},
            "output_tokens": {"type": "integer", "minimum": 0},
            "latency_ms": {"type": "integer", "minimum": 0}
          }
        }
      }
    }
  }
}
